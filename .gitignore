```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.so
*.dll
*.exe
*.class
*.out

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Build directories
dist/
build/
target/
.gradle/

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Coverage reports
coverage/
htmlcov/
.coverage

# IDE specific
.vscode/
.idea/

# OS specific
.DS_Store
Thumbs.db

# Cache directories
.mypy_cache/
.pytest_cache/
```